@{
    ViewData["Title"] = "Doctors";
}

<div>
    <h3>Doc</h3>
    <table>
        <tr>
            <td>id  </td>
            <td>name  </td>
            <td>speciality  </td>
            <td>skill</td>
            <td></td>
        </tr>
        @foreach (var doc in Model)
        {
            <tr>
                <td>@doc.Id</td>
                <td>      </td>
                <td><a href="~/Doctors/ShowDetails/@doc.Id">Show details</a></td>
                <td><a href="~/Doctors/Edit/@doc.Id">Edit</a></td>
                <td><a href="~/Doctors/Delete/@doc.Id">Delete</a></td>
            </tr>
        }
        <tr>
            <td><a href="~/Doctors/Add/">Add new</a></td>
        </tr>
    </table>
</div>
<form method="get" class="form-horizontal" role="form">
    <p></p>
    <div class="form-group">
        <label class="col-md-2 control-label">поиск по слову/части слова:</label>
        <div class="col-md-4">
            <input type="text" name="textToFind" class="form-control" />
        </div>
    </div>
    <div class="form-group">
        <div class="col-md-offset-2 col-md-10">
            <input type="submit" class="btn btn-default" value="Find" />
        </div>
    </div>
</form>